# Shared app config
NODE_ENV=development

# API server
# Set to your public app URL in production (e.g. https://app.example.com)
# This is used for OAuth redirects, Passkey origin, and CORS allowed origins.
APP_URL=http://localhost:3000

# Database / Redis
DATABASE_URL=postgres://postgres:postgres@localhost:5432/drivebase
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-jwt-secret-minimum-32-characters-long-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long-change-this-in-production

# Writable data directory for transfer staging, instance ID, etc.
DATA_DIR=./.drivebase/data
