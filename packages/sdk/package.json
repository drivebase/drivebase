{
	"name": "@drivebase/sdk",
	"version": "1.0.0",
	"description": "TypeScript SDK for the Drivebase API",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"keywords": [
		"drivebase",
		"storage",
		"s3",
		"google-drive",
		"api",
		"sdk",
		"client"
	],
	"repository": {
		"url": "https://github.com/drivebase/drivebase",
		"directory": "packages/sdk"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	},
	"license": "MIT"
}
