{
  "name": "@drivebase/api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "bun run codegen",
    "dev": "DRIVEBASE_CONFIG=../../config.toml bun --hot ./index.ts",
    "prestart": "bun run codegen",
    "start": "bun ./index.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "pretypecheck": "bun run codegen",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.0",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@types/bun": "^1.3.12",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@drivebase/cache": "workspace:*",
    "@drivebase/telemetry": "workspace:*",
    "@drivebase/config": "workspace:*",
    "@drivebase/db": "workspace:*",
    "@drivebase/logger": "workspace:*",
    "@drivebase/provider-google-drive": "workspace:*",
    "@drivebase/provider-local": "workspace:*",
    "@drivebase/provider-s3": "workspace:*",
    "@drivebase/storage": "workspace:*",
    "@drivebase/testing": "workspace:*",
    "@drivebase/upload-staging": "workspace:*",
    "@graphql-tools/graphql-file-loader": "^8.1.13",
    "@graphql-tools/load": "^8.1.9",
    "@graphql-tools/merge": "^9.1.8",
    "@graphql-tools/schema": "^10.0.32",
    "better-auth": "^1.6.5",
    "bullmq": "^5.74.1",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
