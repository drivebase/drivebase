{
	"git": {
		"tagName": "v${version}",
		"commitMessage": "chore: release v${version}",
		"changelog": false
	},
	"hooks": {
		"after:bump": "bun scripts/prepend-pr-notes.ts ${latestTag}"
	},
	"github": {
		"release": false,
		"tokenRef": "GITHUB_TOKEN",
		"releaseName": "v${version}"
	},
	"plugins": {
		"@release-it/bumper": {
			"out": [
				{
					"file": "docker/compose.prod.yaml",
					"type": "text/plain"
				},
				{
					"file": "render.yaml",
					"type": "text/plain"
				}
			]
		}
	}
}
