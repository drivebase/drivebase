{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**"]
    },
    "codegen": {
      "inputs": [
        "codegen.ts",
        "src/gql/operations/**/*.graphql",
        "../../apps/api/graphql/modules/**/*.gql"
      ],
      "outputs": ["src/gql/__generated__/**", "graphql/__generated__/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "^codegen"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
